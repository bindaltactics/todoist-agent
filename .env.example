# Todoist — from the App Management Console (https://developer.todoist.com/appconsole.html)
TODOIST_CLIENT_SECRET=your-todoist-client-secret

# Supabase — run `supabase start` then copy from the CLI output
SUPABASE_URL=http://localhost:54321
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
DATABASE_URL=postgresql://postgres:postgres@localhost:54322/postgres

# Redis (docker-compose)
REDIS_URL=redis://localhost:6379

# LiteLLM (docker-compose) — master key can be anything locally
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-litellm-local-dev

# LLM provider keys — passed through to LiteLLM
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Langfuse — create an account at http://localhost:3000 after `docker compose up`
LANGFUSE_HOST=http://localhost:3000
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
